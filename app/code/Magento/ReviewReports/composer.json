{
    "name": "magento/module-review-reports",
    "description": "Bridge module that adds Magento_Review data into the Magento_Reports admin reports.",
    "config": {
        "sort-packages": true
    },
    "require": {
        "php": "~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "*",
        "magento/module-backend": "*",
        "magento/module-reports": "*",
        "magento/module-review": "*"
    },
    "type": "magento2-module",
    "license": [
        "OSL-3.0",
        "AFL-3.0"
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Magento\\ReviewReports\\": ""
        }
    }
}
